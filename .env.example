# Copy this file to .env and fill in your Spotify app credentials.
# Create an app at https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# The port used for the local OAuth callback server (default: 8888)
# Make sure "http://localhost:8888/callback" is listed as a Redirect URI in your app.
SPOTIFY_REDIRECT_PORT=8888
